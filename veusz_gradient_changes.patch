+
+    # Apply fill
+    if stroke is None:
+        painter.fillPath(path, brush)
+    else:
+        painter.save()
+        painter.setPen(stroke)
+        painter.setBrush(brush)
+        painter.drawPath(path)
+        painter.restore()
